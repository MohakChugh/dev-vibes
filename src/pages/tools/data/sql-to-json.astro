---
import ToolLayout from '@/layouts/ToolLayout.astro';
import SqlToJson from '@/components/tools/SqlToJson';
import { tools } from '@/config/tools';

const tool = tools.find(t => t.id === '9')!;
---

<ToolLayout 
  title={tool.name} 
  description={tool.description} 
  category={tool.category} 
  tags={tool.tags}
>
  <SqlToJson client:load />

  <div slot="seo-content">
    <h2>Convert SQL INSERT Statements to JSON</h2>
    <p>
      If you have a SQL dump or individual `INSERT INTO` statements, this tool can help you convert them into a structured JSON array. This is especially useful for migrating data from a relational database to a NoSQL database or for use in web APIs.
    </p>

    <h2>Key Features</h2>
    <ul>
      <li><strong>Bulk Processing:</strong> Handles multiple INSERT statements at once.</li>
      <li><strong>Smart Type Mapping:</strong> Detects numbers, strings, and NULL values.</li>
      <li><strong>Column Matching:</strong> Automatically maps values to their respective column names.</li>
      <li><strong>Simple & Fast:</strong> A regex-based parser designed for the most common SQL insert syntax.</li>
    </ul>
  </div>
</ToolLayout>
