---
import ToolLayout from '@/layouts/ToolLayout.astro';
import XmlToJson from '@/components/tools/XmlToJson';
import { tools } from '@/config/tools';

const tool = tools.find(t => t.id === '5')!;
---

<ToolLayout 
  title={tool.name} 
  description={tool.description} 
  category={tool.category} 
  tags={tool.tags}
>
  <XmlToJson client:load />

  <div slot="seo-content">
    <h2>Convert XML to JSON Online</h2>
    <p>
      XML (Extensible Markup Language) is often used in legacy systems or for specific file formats like RSS or SVG. Converting it to JSON makes it easier to work with in modern web applications.
    </p>

    <h2>Key Features</h2>
    <ul>
      <li><strong>Attribute Handling:</strong> Correctly parses and maps XML attributes to JSON keys with @ prefix.</li>
      <li><strong>Fast Parsing:</strong> Uses efficient client-side algorithms for quick conversion.</li>
      <li><strong>Nested Structure:</strong> Recursively handles deeply nested XML tags.</li>
      <li><strong>Privacy-First:</strong> Processing happens entirely in your browser; no XML data is sent to a server.</li>
    </ul>
  </div>
</ToolLayout>
