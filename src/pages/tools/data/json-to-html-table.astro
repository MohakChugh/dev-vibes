---
import ToolLayout from '@/layouts/ToolLayout.astro';
import JsonToHtmlTable from '@/components/tools/JsonToHtmlTable';
import { tools } from '@/config/tools';

const tool = tools.find(t => t.id === '10')!;
---

<ToolLayout 
  title={tool.name} 
  description={tool.description} 
  category={tool.category} 
  tags={tool.tags}
>
  <JsonToHtmlTable client:load />

  <div slot="seo-content">
    <h2>Convert JSON to HTML Table Online</h2>
    <p>
      Displaying JSON data in a readable format is a common task. This tool allows you to instantly turn any JSON array of objects into a clean, styled HTML table. You can use the generated markup in your own projects or emails.
    </p>

    <h2>Key Features</h2>
    <ul>
      <li><strong>Automatic Header Detection:</strong> Uses the keys of the first object in the array as table headers.</li>
      <li><strong>Responsive Preview:</strong> See how your table looks immediately.</li>
      <li><strong>Clean Markup:</strong> Generates standard HTML `table`, `thead`, `tbody`, `tr`, `th`, and `td` tags.</li>
      <li><strong>Handles Nested Data:</strong> Objects and arrays within the JSON are automatically stringified for display.</li>
    </ul>
  </div>
</ToolLayout>
