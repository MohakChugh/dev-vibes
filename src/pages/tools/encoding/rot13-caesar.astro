---
import ToolLayout from '@/layouts/ToolLayout.astro';
import EncoderDecoder from '@/components/EncoderDecoder';
import { rot13 } from '@/tools/encoding/encodingTools';
import { tools } from '@/config/tools';
const tool = tools.find(t => t.id === '19')!;
---
<ToolLayout {...tool}><EncoderDecoder client:load onEncode={rot13} onDecode={rot13} /></ToolLayout>
