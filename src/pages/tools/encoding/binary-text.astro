---
import ToolLayout from '@/layouts/ToolLayout.astro';
import EncoderDecoder from '@/components/EncoderDecoder';
import { textToBinary, binaryToText } from '@/tools/encoding/encodingTools';
import { tools } from '@/config/tools';
const tool = tools.find(t => t.id === '15')!;
---
<ToolLayout {...tool}><EncoderDecoder client:load onEncode={textToBinary} onDecode={binaryToText} /></ToolLayout>
