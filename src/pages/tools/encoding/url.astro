---
import ToolLayout from '@/layouts/ToolLayout.astro';
import EncoderDecoder from '@/components/EncoderDecoder';
import { urlEncode, urlDecode } from '@/tools/encoding/encodingTools';
import { tools } from '@/config/tools';
const tool = tools.find(t => t.id === '12')!;
---
<ToolLayout {...tool}><EncoderDecoder client:load onEncode={urlEncode} onDecode={urlDecode} /></ToolLayout>
