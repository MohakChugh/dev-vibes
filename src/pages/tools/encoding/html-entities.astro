---
import ToolLayout from '@/layouts/ToolLayout.astro';
import EncoderDecoder from '@/components/EncoderDecoder';
import { htmlEncode, htmlDecode } from '@/tools/encoding/encodingTools';
import { tools } from '@/config/tools';
const tool = tools.find(t => t.id === '14')!;
---
<ToolLayout {...tool}><EncoderDecoder client:load onEncode={htmlEncode} onDecode={htmlDecode} /></ToolLayout>
