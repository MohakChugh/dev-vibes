---
import ToolLayout from '@/layouts/ToolLayout.astro';
import EncoderDecoder from '@/components/EncoderDecoder';
import { base64Encode, base64Decode } from '@/tools/encoding/encodingTools';
import { tools } from '@/config/tools';
const tool = tools.find(t => t.id === '11')!;
---
<ToolLayout {...tool}><EncoderDecoder client:load onEncode={base64Encode} onDecode={base64Decode} /></ToolLayout>
