---
import ToolLayout from '@/layouts/ToolLayout.astro';
import EncoderDecoder from '@/components/EncoderDecoder';
import { textToMorse, morseToText } from '@/tools/encoding/encodingTools';
import { tools } from '@/config/tools';
const tool = tools.find(t => t.id === '20')!;
---
<ToolLayout {...tool}><EncoderDecoder client:load onEncode={textToMorse} onDecode={morseToText} /></ToolLayout>
